{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ESNext"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": false,
		"experimentalDecorators": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["src/**/*.ts", "demo/**/*.ts"]
}
