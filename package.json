{
  "name": "aml",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "aml": "dist/bin.mjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "link": "pnpm build && pnpm add --global .",
    "unlink": "pnpm remove --global aml",
    "pc": "aml compile --input ./playground/input.aml --output ./playground/output"
  },
  "license": "MIT",
  "dependencies": {
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  }
}