{
  "name": "@jml/core",
  "version": "0.0.1",
  "description": "JML compiler core - parser, AST, transformer, and code generator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
