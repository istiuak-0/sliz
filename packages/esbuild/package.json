{
  "name": "@jml/esbuild",
  "version": "0.0.1",
  "description": "esbuild plugin for JML",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "@jml/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "esbuild": "^0.24.0"
  },
  "peerDependencies": {
    "esbuild": "^0.24.0"
  }
}
