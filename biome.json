{
	"$schema": "https://biomejs.dev/schemas/1/schema.json",
	"organizeImports": {
		"enabled": false
	},
	"linter": {
		"enabled": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 200
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"trailingCommas": "all"
		}
	},
	"files": {
		"ignore": ["node_modules", "dist", "pnpm-lock.yaml", "*.lock"]
	}
}
